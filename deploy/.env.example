# Assay — environment variables
# Copy this file to .env and fill in all values before running docker compose up

# Admin login email for the dashboard
ASSAY_ADMIN_EMAIL=you@yourdomain.com

# Bcrypt hash of your dashboard password
# Generate with: uv run python -c "from assay.auth.admin import hash_password; print(hash_password('yourpassword'))"
ASSAY_ADMIN_PASSWORD_HASH=$2b$12$...

# Shared Warden secret — must match WARDEN_SECRET in daemon and conclave
# Generate with: python3 -c "import secrets; print(secrets.token_urlsafe(48))"
WARDEN_SECRET=change-me-to-a-long-random-string
