{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "assay:payload",
  "title": "Assay Result Payload",
  "description": "Payload produced by Assay and written to the configured output directory. One file per run, named assay-<timestamp>-<uuid>.json.",
  "type": "object",
  "required": ["verification_id", "task_id", "issue_type", "severity", "outcome", "summary"],
  "additionalProperties": false,
  "properties": {
    "verification_id": {
      "type": "string",
      "minLength": 1,
      "description": "Stable ID assigned by Assay at submission time."
    },
    "task_id": {
      "type": ["string", "null"],
      "description": "Grain task packet ID being verified (e.g. TASK-0070). Null for standalone runs."
    },
    "issue_type": {
      "type": "string",
      "enum": ["test_failure", "bug_finding", "screenshot_evidence", "trace_capture", "human_annotation", "code_review"],
      "description": "Category of the verification finding."
    },
    "severity": {
      "type": "string",
      "enum": ["info", "warning", "error", "critical"],
      "description": "Severity level of the finding."
    },
    "outcome": {
      "type": "string",
      "enum": ["pass", "fail", "inconclusive"],
      "description": "Verification result."
    },
    "summary": {
      "type": "string",
      "minLength": 1,
      "description": "Human-readable description of the finding."
    },
    "artifact_refs": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "description": "Paths or URIs to captured artifacts (screenshots, logs, traces)."
    },
    "followup_candidates": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["title", "description"],
        "additionalProperties": false,
        "properties": {
          "title": { "type": "string", "minLength": 1 },
          "description": { "type": "string", "minLength": 1 }
        }
      },
      "description": "Proposed follow-up work items for operator review."
    },
    "verified_at": {
      "type": ["string", "null"],
      "format": "date-time",
      "description": "ISO 8601 datetime when Assay completed the verification run."
    },
    "url": {
      "type": ["string", "null"],
      "description": "URL of the page captured (populated by SDK ingest path)."
    },
    "diff_result": {
      "type": ["object", "null"],
      "description": "Pixel diff result against the baseline for this URL.",
      "properties": {
        "changed_pixels": { "type": "integer" },
        "total_pixels": { "type": "integer" },
        "diff_pct": { "type": "number" },
        "diff_image_path": { "type": "string" }
      }
    },
    "review": {
      "type": ["object", "null"],
      "additionalProperties": false,
      "required": ["verdict"],
      "description": "Structured code-review verdict block, populated when issue_type is code_review.",
      "properties": {
        "verdict": { "type": "string", "enum": ["pass", "fail", "inconclusive"] },
        "findings": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["file", "severity", "message"],
            "properties": {
              "file": { "type": "string", "minLength": 1 },
              "line": { "type": ["integer", "null"] },
              "severity": { "type": "string", "enum": ["info", "warning", "error", "critical"] },
              "message": { "type": "string", "minLength": 1 }
            }
          }
        },
        "reviewers": { "type": "array", "items": { "type": "string", "minLength": 1 } },
        "confidence": { "type": "number", "minimum": 0, "maximum": 1 }
      }
    }
  }
}
